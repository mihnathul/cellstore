# Python
__pycache__/
*.py[cod]
*.pyo
*.egg
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtual environments
.venv/
venv/
env/
.env

# Editors / IDEs
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
.DS_Store

# Jupyter
.ipynb_checkpoints/

# Coverage
.coverage
htmlcov/

# pip
pip-log.txt
pip-delete-this-directory.txt

# Raw data (keep README.md files for download instructions)
data/raw/**/*.mat
data/raw/**/*.csv
data/raw/**/*.xlsx
data/raw/**/*.h5
data/raw/**/*.hdf5
data/raw/**/*.zip
data/raw/**/*.parquet
data/raw/**/*.txt

# ORNL Leaf is the one bundled source — un-ignore its CSVs
!data/raw/ornl_leaf/*.csv

# Harmonized outputs — users regenerate locally via the demo, OR
# download the full bundle from HuggingFace (huggingface.co/datasets/
# mihnathul/celljar). Bundled exception: ORNL_LEAF and HNEI metadata
# JSONs ship in the repo so a fresh clone has at least 2 sources of
# example metadata to inspect without running the demo. The actual
# timeseries / cycle_summary parquet files are NOT in git (too large —
# 3+ GB regenerated; HF is the proper distribution).
data/harmonized/cells/*.json
data/harmonized/tests/*.json
data/harmonized/timeseries/
!data/harmonized/cells/ORNL_LEAF_2013.json
!data/harmonized/tests/ORNL_LEAF_2013_HPPC_*.json
!data/harmonized/cells/HNEI_PANASONIC_18650PF.json
!data/harmonized/tests/HNEI_PANASONIC_18650PF_HPPC_*.json

# Other derived data
data/params/
data/exports/
*.parquet

# Streamlit runtime secrets (keep config.toml)
.streamlit/secrets.toml
